# AgniAI Environment Configuration
# Copy this file to .env and edit the values
# cp .env.example .env

# ── Ollama ─────────────────────────────────────────────────────────────────
# URL where Ollama is running
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Primary LLM model (must be pulled with: ollama pull <model>)
# Options: mistral:7b-instruct-q4_K_M | llama3:8b | phi3 | gemma2:2b
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M

# Comma-separated fallback models tried if primary is unavailable
OLLAMA_FALLBACK_MODELS=mistral:7b-instruct-q4_K_M,mistral:7b-instruct,llama3:8b,llama3.2:3b,gemma2:2b

# Context window size (tokens). 4096 is safe for 7B models on 8GB RAM
OLLAMA_NUM_CTX=4096

# Max tokens to generate per response
OLLAMA_MAX_TOKENS=1200

# Temperature (0.0 = deterministic, 1.0 = creative). Keep low for factual QA
OLLAMA_TEMPERATURE=0.05

# How long to keep model in RAM after last request (-1 = forever, "10m" = 10 minutes)
OLLAMA_KEEP_ALIVE=10m

# Number of CPU threads for inference (default: all physical cores - 1)
# OLLAMA_NUM_THREAD=4

# Timeout settings (seconds)
OLLAMA_CONNECT_TIMEOUT=8
OLLAMA_FIRST_TOKEN_TIMEOUT=180
OLLAMA_STREAM_TIMEOUT=300
OLLAMA_MAX_RETRIES=2

# ── Embeddings ─────────────────────────────────────────────────────────────
# Local embedding model (downloaded once, then cached offline)
EMBEDDING_MODEL=sentence-transformers/multi-qa-MiniLM-L6-cos-v1

# Must match the model's output dimension (384 for MiniLM, 768 for mpnet)
EMBEDDING_DIM=384

# Optional cross-encoder reranker (disabled by default — adds latency)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
USE_RERANKER=0

# ── Retrieval ──────────────────────────────────────────────────────────────
# Number of chunks to retrieve per query
TOP_K=5

# Enable hybrid FAISS + BM25 retrieval (recommended: 1)
USE_HYBRID=1

# FAISS dense vs BM25 keyword weight (must sum to 1.0)
DENSE_WEIGHT=0.60
BM25_WEIGHT=0.40

# Minimum similarity score to include a chunk
MIN_SCORE=0.20

# Strict minimum for high-confidence answers
STRICT_MIN_SCORE=0.55

# Retrieval confidence thresholds
LOW_RETRIEVAL_CONFIDENCE=0.35
HIGH_RETRIEVAL_CONFIDENCE=0.60

# ── Chunking ───────────────────────────────────────────────────────────────
CHUNK_WORDS=420
CHUNK_OVERLAP=80
CHUNK_MIN_WORDS=12

# ── Context window limits (characters, per style) ──────────────────────────
MAX_CONTEXT_CHARS_SHORT=1000
MAX_CONTEXT_CHARS_ELABORATE=1800
MAX_CONTEXT_CHARS_DETAIL=2800
MAX_CONTEXT_CHARS_DEFAULT=1800

# ── Token budgets for completion (per style) ───────────────────────────────
MAX_TOKENS_SHORT=250
MAX_TOKENS_ELABORATE=500
MAX_TOKENS_DETAIL=800
MAX_TOKENS_DEFAULT=500
TOKEN_SAFETY_BUFFER=100

# ── Caching ────────────────────────────────────────────────────────────────
# Retrieval cache TTL in seconds (1 hour default — Agniveer data changes annually)
RETRIEVAL_CACHE_TTL=3600

# Response cache TTL in seconds (24 hours default)
RESPONSE_CACHE_TTL=86400

# Embedding cache TTL in seconds (24 hours default)
EMBED_CACHE_TTL=86400

# Maximum number of cache entries
MAX_CACHE_ENTRIES=2048

# ── Memory ─────────────────────────────────────────────────────────────────
# Number of conversation turns to keep in sliding window
MEMORY_MAX_MESSAGES=10

# ── Network ────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=120
FIRST_TOKEN_TIMEOUT=30
STREAM_TIMEOUT=300

# ── Flask REST API ─────────────────────────────────────────────────────────
# Allowed CORS origins (* = allow all, use specific domain in production)
ALLOWED_ORIGINS=*

# Session header name
SESSION_HEADER=X-Session-Id

# Optional API secret key for protecting destructive endpoints
# Set this in production! e.g. API_SECRET_KEY=your-random-secret-here
# API_SECRET_KEY=
