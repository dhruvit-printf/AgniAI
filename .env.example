# AgniAI Environment Configuration
# Copy this file to .env and edit the values
# cp .env.example .env

# ── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M
OLLAMA_FALLBACK_MODELS=mistral:7b-instruct-q4_K_M,mistral:7b-instruct,llama3:8b,llama3.2:3b,gemma2:2b
OLLAMA_NUM_CTX=8192
OLLAMA_MAX_TOKENS=1500
OLLAMA_TEMPERATURE=0.05

# FIX #4 — KEEP_ALIVE:
#   "10m"  = unload model after 10 minutes of idle (saves RAM)
#   "-1"   = keep model loaded forever (fastest response time, uses more RAM)
# The heartbeat thread pings Ollama every 5 min regardless of this setting
# to prevent eviction during active sessions.
OLLAMA_KEEP_ALIVE=10m

# OLLAMA_NUM_THREAD=4
OLLAMA_CONNECT_TIMEOUT=8
OLLAMA_FIRST_TOKEN_TIMEOUT=180
OLLAMA_STREAM_TIMEOUT=300
OLLAMA_MAX_RETRIES=2

# ── Embeddings ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/multi-qa-MiniLM-L6-cos-v1
EMBEDDING_DIM=384
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
USE_RERANKER=0

# ── Retrieval ──────────────────────────────────────────────────────────────
TOP_K=5
USE_HYBRID=1
DENSE_WEIGHT=0.60
BM25_WEIGHT=0.40
MIN_SCORE=0.20
STRICT_MIN_SCORE=0.55
LOW_RETRIEVAL_CONFIDENCE=0.35
HIGH_RETRIEVAL_CONFIDENCE=0.60

# ── Chunking ───────────────────────────────────────────────────────────────
CHUNK_WORDS=420
CHUNK_OVERLAP=80
CHUNK_MIN_WORDS=12

# ── Context window limits (characters, per style) ──────────────────────────
# FIX #3 — these are used directly as char budgets (no token*4 heuristic)
MAX_CONTEXT_CHARS_SHORT=1000
MAX_CONTEXT_CHARS_ELABORATE=1800
MAX_CONTEXT_CHARS_DETAIL=2800
MAX_CONTEXT_CHARS_DEFAULT=1800

# ── Token budgets for completion (per style) ───────────────────────────────
MAX_TOKENS_SHORT=250
MAX_TOKENS_ELABORATE=700
MAX_TOKENS_DETAIL=1100
MAX_TOKENS_DEFAULT=600
TOKEN_SAFETY_BUFFER=100

# ── Caching ────────────────────────────────────────────────────────────────
RETRIEVAL_CACHE_TTL=3600
RESPONSE_CACHE_TTL=86400
EMBED_CACHE_TTL=86400
MAX_CACHE_ENTRIES=2048

# ── Memory ─────────────────────────────────────────────────────────────────
MEMORY_MAX_MESSAGES=20

# ── Network ────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=120
FIRST_TOKEN_TIMEOUT=30
STREAM_TIMEOUT=300

# ── Flask REST API ─────────────────────────────────────────────────────────
# Set to * for open access, or comma-separated origins for production:
# ALLOWED_ORIGINS=https://your-ngrok-url.ngrok-free.app,http://localhost:3000
ALLOWED_ORIGINS=*

SESSION_HEADER=X-Session-Id

# Optional API secret key for protecting destructive endpoints (/api/reset_index)
# Set this in production!
# API_SECRET_KEY=your-random-secret-here

# ── FIX #8 — Rate limiting (Flask-Limiter) ─────────────────────────────────
# Format: "N per period" where period = second | minute | hour | day
RATE_LIMIT_CHAT=30 per minute
RATE_LIMIT_INGEST=10 per minute
RATE_LIMIT_DEFAULT=60 per minute

# ── FIX #11 — Logging ──────────────────────────────────────────────────────
# Log file path (relative to project root or absolute)
AGNI_LOG_FILE=agni.log
